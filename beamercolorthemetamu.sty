% Texas A&M University color theme for Gemini
% https://github.com/anishathalye/gemini

% ====================
% Colors
% ====================

\definecolor{tamu-maroon}{HTML}{500000}
\definecolor{tamu-white}{HTML}{ffffff}
\definecolor{tamu-gray}{HTML}{d6d6d6}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{palette secondary}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{palette tertiary}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{palette quaternary}{fg=tamu-white,bg=tamu-maroon}

% Headline
\setbeamercolor{headline}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{headline title}{fg=tamu-white}
\setbeamercolor{headline author}{fg=tamu-white}
\setbeamercolor{headline institute}{fg=tamu-white}

% Block
\setbeamercolor{block title}{fg=tamu-maroon,bg=tamu-white}
\setbeamercolor{block separator}{bg=tamu-gray}
\setbeamercolor{block body}{fg=black,bg=tamu-white}

% Alert Block
\setbeamercolor{block title alerted}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{block separator alerted}{bg=tamu-gray}
\setbeamercolor{block body alerted}{fg=black,bg=tamu-white}

% Example Block
\setbeamercolor{block title example}{fg=tamu-white,bg=tamu-maroon}
\setbeamercolor{block separator example}{bg=tamu-gray}
\setbeamercolor{block body example}{fg=black,bg=tamu-white}

% Heading
\setbeamercolor{heading}{fg=tamu-maroon}

% Itemize
\setbeamercolor{itemize item}{fg=tamu-maroon}
\setbeamercolor{itemize subitem}{fg=tamu-maroon}
\setbeamercolor{itemize subsubitem}{fg=tamu-maroon}
